# Kubernetes MCP Server 本地环境变量示例
# 使用方式：
#   1. cp env.example .env
#   2. 按需修改 .env
#   3. uv sync
#   4. k8s-mcp-server --transport streamable --host 0.0.0.0 --port 8000
#
# 注意：
# - config.py 会默认读取当前工作目录下的 .env
# - 系统环境变量优先级更高，.env 不会覆盖已存在的环境变量
# - 不要提交真实 .env、JWT Secret、管理员 Token 或 kubeconfig

# ---------- 数据目录 ----------
# 优先级：MCP_DATA_DIR > DATA_DIR > 项目内 data/
MCP_DATA_DIR=./data
# DATA_DIR=./data

# 备份保留天数（按文件修改时间计算）；0 表示永不清理
MCP_BACKUP_RETENTION_DAYS=90

# Pod 文件读取单文件上限（字节），默认 10MB
MAX_POD_FILE_SIZE=10485760

# ---------- JWT / 多租户认证 ----------
# 本地调试默认关闭；多人/线上使用建议开启
MCP_AUTH_ENABLED=false

# 启用认证时必须设置，建议至少 32 字节随机字符串
# 生成示例：openssl rand -base64 32
MCP_JWT_SECRET=

MCP_JWT_ALGORITHM=HS256
MCP_JWT_AUDIENCE=k8s-mcp-server

# Token 最大有效期（秒），默认 90 天
MCP_TOKEN_MAX_EXPIRY=7776000

# 管理 API 前缀
MCP_ADMIN_API_PREFIX=/admin

# 可选：启动前预置管理员 JWT。通常由 `mcp-admin bootstrap` 生成。
MCP_BOOTSTRAP_ADMIN_JWT=

# 健康检查路径（无需鉴权）
MCP_HEALTH_PATH=/health

# ---------- 服务监听 ----------
LOG_LEVEL=info
SSE_HOST=0.0.0.0
SSE_PORT=8000

# ---------- MCP 路径 ----------
# Streamable HTTP 标准单端点，推荐 Cursor 等 HTTP MCP 客户端使用
MCP_STREAMABLE_PATH=/mcp

# SSE 兼容端点：GET /sse + POST /message
MCP_SSE_PATH=/sse
MCP_MESSAGE_PATH=/message

# ---------- FastMCP 行为 ----------
MCP_DEBUG=false
MCP_LOG_LEVEL=INFO
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_MOUNT_PATH=/
MCP_JSON_RESPONSE=false
MCP_STATELESS_HTTP=false
MCP_WARN_DUPLICATE_RESOURCES=true
MCP_WARN_DUPLICATE_TOOLS=true
MCP_WARN_DUPLICATE_PROMPTS=true

# 逗号分隔的额外依赖名称，通常保持为空
MCP_DEPENDENCIES=

# 显示本地时间时使用的时区偏移（默认东八区）
TIMEZONE_OFFSET_HOURS=8

# ---------- .env 加载控制 ----------
# 默认读取当前工作目录下的 .env，如需自定义文件名/路径，可在启动前通过系统环境变量设置。
# MCP_ENV_FILE=.env
# MCP_ENV_FILE_ENCODING=utf-8
